# SonarQube Environment Configuration
# For development: cp .env.sonarqube.example .env.sonarqube

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# SonarQube Server Configuration
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Base URL for SonarQube (no trailing slash)
SONAR_HOST_URL=http://sonarqube:9000

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Database Configuration
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# PostgreSQL Connection
SONAR_JDBC_URL=jdbc:postgresql://postgres-sonar:5432/sonar
SONAR_JDBC_USERNAME=sonar
SONAR_JDBC_PASSWORD=sonar_password_2024

# Alternatively for MySQL (if using MySQL instead)
# SONAR_JDBC_URL=jdbc:mysql://mysql-sonar:3306/sonar
# SONAR_JDBC_USERNAME=sonar
# SONAR_JDBC_PASSWORD=sonar_password_2024

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Administrator Credentials
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# ⚠️ IMPORTANT: Change immediately after first login!
SONARQUBE_ADMIN_USER=admin
SONARQUBE_ADMIN_PASSWORD=admin_password_2024

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Java & Performance Tuning
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Web server Java options (for larger analysis)
# Development: 1GB, Production: 2-4GB
SONAR_WEB_JAVAADDITIONALOPTS=-Xmx1024m -XX:+HeapDumpOnOutOfMemoryError

# Search/Elasticsearch Java options
SONAR_SEARCH_JAVAADDITIONALOPTS=-Xmx512m

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Security Configuration
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Elasticsearch security (disable in development, enable in production)
SONAR_ES_BOOTSTRAP_CHECKS_DISABLE=true

# Force HTTPS (production only)
SONAR_CORE_SERVER_BASE_URL=http://sonarqube:9000
# SONAR_CORE_SERVER_BASE_URL=https://sonarqube.studysmart.com

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Project Keys & Tokens
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Jenkins/CI Integration Token (generate in UI)
# Admin → Security → Users → Generate Token
SONAR_LOGIN_TOKEN=your_jenkins_token_here

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Email Configuration (for notifications)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

SONAR_NOTIFICATIONS_EMAIL_ENABLED=false

# SMTP Server (if email notifications enabled)
# SONAR_SMTP_HOST=mail.example.com
# SONAR_SMTP_PORT=587
# SONAR_SMTP_USERNAME=sonar@example.com
# SONAR_SMTP_PASSWORD=email_password
# SONAR_SMTP_FROM=sonar@example.com

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# LDAP Integration (optional)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# SONAR_SECURITY_REALM=LDAP
# SONAR_LDAP_URL=ldap://ldap.example.com:389
# SONAR_LDAP_BIND_DN=cn=admin,dc=example,dc=com
# SONAR_LDAP_BIND_PASSWORD=ldap_password

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Logging Configuration
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Log level: DEBUG, INFO, WARN, ERROR
SONAR_LOG_LEVEL=INFO

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# PostgreSQL-specific Settings
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# PostgreSQL Connection Pool
SONAR_JDBC_MAX_POOL_SIZE=20
SONAR_JDBC_MIN_IDLE_CONNECTIONS=2

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Docker-specific Settings
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Allow running inside Docker
SONAR_SEARCH_ES_BOOTSTRAP_CHECKS_DISABLE=true

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Quality Profiles & Rules
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Quality profile to use (Sonar Way is default)
# Configure in UI: Administration → Quality Profiles

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Plugins (if custom plugins needed)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Install plugins via UI: Administration → Marketplace
# Common plugins: SonarJS, SonarPython, SonarGo, etc.

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Development/Testing
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# For local testing only - skip Elasticsearch bootstrap checks
SONARQUBE_JDBC_URL=jdbc:postgresql://postgres-sonar:5432/sonar
SONARQUBE_JDBC_USERNAME=sonar
SONARQUBE_JDBC_PASSWORD=sonar_password_2024

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Notes:
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# 1. For development: use provided defaults
# 2. For production: update all passwords and credentials
# 3. Use strong passwords (min 12 chars, mixed case, numbers, symbols)
# 4. Store sensitive data in secrets manager
# 5. Enable HTTPS in production
# 6. Regular backups of SonarQube database
# 7. Monitor disk space for analysis data
# 8. Update SonarQube regularly for security patches
