# ─── Database ─────────────────────────────────────────────────────────────────
DB_HOST=postgres
DB_PORT=5432
DB_USER=studysmart
DB_PASSWORD=changeme
DB_NAME=studysmart_db

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=replace_with_a_long_random_secret_at_least_32_chars

# ─── Services ─────────────────────────────────────────────────────────────────
NODE_ENV=production

# ─── Stripe (optional — leave as placeholder to run in mock mode) ─────────────
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder

# ─── Frontend ─────────────────────────────────────────────────────────────────
# Leave empty so React calls relative /api/ paths through nginx
REACT_APP_API_URL=
