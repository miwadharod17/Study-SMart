pipeline {
    agent any
    
    options {
        timeout(time: 1, unit: 'HOURS')
        timestamps()
        buildDiscarder(logRotator(numToKeepStr: '30'))
    }
    
    environment {
        DOCKER_REGISTRY = 'docker.io/studysmart'
        K8S_NAMESPACE = 'study-smart'
        SONAR_HOST_URL = 'http://sonarqube:9000'
        SONAR_LOGIN = credentials('sonarqube-token')
        REGISTRY_CREDENTIALS = credentials('docker-registry-credentials')
    }
    
    stages {
        stage('Checkout') {
            steps {
                checkout scm
                sh 'git log -1 --pretty=format:"%H %s" > git_info.txt'
            }
        }
        
        stage('SonarQube Analysis') {
            steps {
                script {
                    withSonarQubeEnv('SonarQube') {
                        sh '''
                            echo "Installing dependencies..."
                            npm install
                            
                            echo "Running tests with coverage..."
                            npm run test:coverage || true
                            
                            echo "Scanning with SonarQube..."
                            sonar-scanner \
                              -Dsonar.projectKey=study-smart-main \
                              -Dsonar.sources=. \
                              -Dsonar.host.url=${SONAR_HOST_URL} \
                              -Dsonar.login=${SONAR_LOGIN}
                        '''
                    }
                }
            }
        }
        
        stage('SonarQube Quality Gate') {
            steps {
                script {
                    timeout(time: 5, unit: 'MINUTES') {
                        def qg = waitForQualityGate()
                        if (qg.status != 'OK') {
                            echo "Quality Gate failed: ${qg.status}"
                            error "Quality Gate failed for project - stopping build"
                        } else {
                            echo "Quality Gate passed successfully"
                        }
                    }
                }
            }
        }
        
        
        stage('Build Docker Images') {
            parallel {
                stage('Build Payment') {
                    steps {
                        script {
                            dir('backend/services/payment-service') {
                                sh '''
                                    docker build \
                                      -t ${DOCKER_REGISTRY}/payment-service:${BUILD_NUMBER} \
                                      -t ${DOCKER_REGISTRY}/payment-service:latest \
                                      --build-arg BUILD_NUMBER=${BUILD_NUMBER} \
                                      .
                                '''
                            }
                        }
                    }
                }
                stage('Build Forum') {
                    steps {
                        script {
                            dir('backend/services/forum-service') {
                                sh '''
                                    docker build \
                                      -t ${DOCKER_REGISTRY}/forum-service:${BUILD_NUMBER} \
                                      -t ${DOCKER_REGISTRY}/forum-service:latest \
                                      --build-arg BUILD_NUMBER=${BUILD_NUMBER} \
                                      .
                                '''
                            }
                        }
                    }
                }
                stage('Build CRUD') {
                    steps {
                        script {
                            dir('backend/services/crud-service') {
                                sh '''
                                    docker build \
                                      -t ${DOCKER_REGISTRY}/crud-service:${BUILD_NUMBER} \
                                      -t ${DOCKER_REGISTRY}/crud-service:latest \
                                      --build-arg BUILD_NUMBER=${BUILD_NUMBER} \
                                      .
                                '''
                            }
                        }
                    }
                }
                stage('Build Frontend') {
                    steps {
                        script {
                            dir('frontend') {
                                sh '''
                                    docker build \
                                      -t ${DOCKER_REGISTRY}/frontend:${BUILD_NUMBER} \
                                      -t ${DOCKER_REGISTRY}/frontend:latest \
                                      --build-arg BUILD_NUMBER=${BUILD_NUMBER} \
                                      .
                                '''
                            }
                        }
                    }
                }
            }
        }
        
        stage('Push to Registry') {
            steps {
                script {
                    sh '''
                        echo $REGISTRY_CREDENTIALS_PSW | docker login -u $REGISTRY_CREDENTIALS_USR --password-stdin
                        docker push ${DOCKER_REGISTRY}/payment-service:${BUILD_NUMBER}
                        docker push ${DOCKER_REGISTRY}/forum-service:${BUILD_NUMBER}
                        docker push ${DOCKER_REGISTRY}/crud-service:${BUILD_NUMBER}
                        docker push ${DOCKER_REGISTRY}/frontend:${BUILD_NUMBER}
                        docker logout
                    '''
                }
            }
        }
        
        stage('Deploy to Kubernetes') {
            steps {
                script {
                    withKubeConfig([credentialsId: 'kubeconfig']) {
                        sh '''
                            kubectl set image deployment/payment-service \
                              payment=${DOCKER_REGISTRY}/payment-service:${BUILD_NUMBER} \
                              -n ${K8S_NAMESPACE}
                            kubectl set image deployment/forum-service \
                              forum=${DOCKER_REGISTRY}/forum-service:${BUILD_NUMBER} \
                              -n ${K8S_NAMESPACE}
                            kubectl set image deployment/crud-service \
                              crud=${DOCKER_REGISTRY}/crud-service:${BUILD_NUMBER} \
                              -n ${K8S_NAMESPACE}
                            kubectl set image deployment/frontend \
                              frontend=${DOCKER_REGISTRY}/frontend:${BUILD_NUMBER} \
                              -n ${K8S_NAMESPACE}
                            
                            echo "Waiting for rollout..."
                            kubectl rollout status deployment/payment-service -n ${K8S_NAMESPACE} --timeout=5m
                            kubectl rollout status deployment/forum-service -n ${K8S_NAMESPACE} --timeout=5m
                            kubectl rollout status deployment/crud-service -n ${K8S_NAMESPACE} --timeout=5m
                            kubectl rollout status deployment/frontend -n ${K8S_NAMESPACE} --timeout=5m
                        '''
                    }
                }
            }
        }
        }
        
        
        stage('Smoke Tests') {
            steps {
                script {
                    sh '''
                        echo "Running smoke tests..."
                        sleep 10
                        curl -f http://api.studysmart.com/health || true
                        curl -f http://studysmart.com || true
                    '''
                }
            }
        }
        
        stage('Rollback if Failed') {
            when {
                expression { currentBuild.result == 'FAILURE' }
            }
            steps {
                script {
                    withKubeConfig([credentialsId: 'kubeconfig']) {
                        sh '''
                            echo "Deployment failed, initiating rollback..."
                            kubectl rollout undo deployment/payment-service -n ${K8S_NAMESPACE}
                            kubectl rollout undo deployment/forum-service -n ${K8S_NAMESPACE}
                            kubectl rollout undo deployment/crud-service -n ${K8S_NAMESPACE}
                            kubectl rollout undo deployment/frontend -n ${K8S_NAMESPACE}
                        '''
                    }
                }
            }
        }
    }
    
    post {
        success {
            script {
                slackSend(
                    color: 'good',
                    message: """✅ Deployment Successful!
Build: ${BUILD_NUMBER}
Project: Study-SMart
SonarQube Quality Gate: ✓ PASSED
Docker Images: ✓ PUSHED
Kubernetes: ✓ DEPLOYED
Branch: ${GIT_BRANCH}
Commit: ${GIT_COMMIT.take(8)}"""
                )
            }
        }
        failure {
            script {
                slackSend(
                    color: 'danger',
                    message: """❌ Deployment Failed!
Build: ${BUILD_NUMBER}
Project: Study-SMart
Branch: ${GIT_BRANCH}
Commit: ${GIT_COMMIT.take(8)}
Check Jenkins logs for details."""
                )
            }
        }
        always {
            cleanWs()
        }
    }
}
